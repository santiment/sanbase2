{
  "name": "sanbase-mcp-widgets",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@8.15.9",
  "scripts": {
    "dev": "vite",
    "build": "pnpm run build:chart && pnpm run build:social-trends && pnpm run build:clean",
    "build:chart": "WIDGET=chart vite build",
    "build:social-trends": "WIDGET=social-trends vite build",
    "build:clean": "find ../../priv/mcp_widgets -type f ! -name '*.html' -delete",
    "check": "svelte-check --tsconfig ./tsconfig.app.json && tsc -p tsconfig.node.json"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tsconfig/svelte": "^5.0.8",
    "@types/node": "^24.12.3",
    "svelte": "^5.55.5",
    "svelte-check": "^4.4.8",
    "typescript": "~6.0.2",
    "vite": "^8.0.12",
    "vite-plugin-singlefile": "^2.3.3"
  },
  "dependencies": {
    "@melt-ui/svelte": "^0.86.6",
    "@modelcontextprotocol/ext-apps": "^1.7.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@santiment-network/chart-next": "npm:@santiment-network/chart@^1.0.22",
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.14",
    "san-webkit-next": "github:santiment/san-webkit#lib-64bf6a43-070526",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^3.4.19"
  }
}
