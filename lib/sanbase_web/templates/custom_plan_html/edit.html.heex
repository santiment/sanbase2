<div class="max-w-4xl mx-auto py-8">
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-3xl font-bold text-base-content">Edit Custom Plan</h1>
    <.link
      href={~p"/admin/custom_plans"}
      class="link link-primary font-medium"
    >
      Back to Plans
    </.link>
  </div>

  <SanbaseWeb.CustomPlanHTML.edit_form
    form={@form}
    custom_plan={@custom_plan}
    action={~p"/admin/custom_plans/#{@custom_plan}"}
  />
</div>
