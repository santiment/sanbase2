<div class="max-w-4xl mx-auto py-8">
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-3xl font-bold text-gray-800">New Custom Plan</h1>
    <%= link "Back to Plans", to: Routes.custom_plan_path(@conn, :index), class: "text-indigo-600 hover:text-indigo-800 font-medium" %>
  </div>

  <%= render "form.html", Map.put(assigns, :action, Routes.custom_plan_path(@conn, :create)) %>
</div>
